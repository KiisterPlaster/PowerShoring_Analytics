# PowerShoring Analytics — Environment Variables
# Copy this file to .env and fill in your keys

DEBUG=true

# PostGIS Database
DATABASE_URL=postgresql://powershoring:powershoring@localhost:5432/powershoring_db

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0

# OpenAI API Key (required for Matchmaker)
OPENAI_API_KEY=sk-your-key-here

# OpenAI Model
OPENAI_MODEL=gpt-4o

# Firebase Storage Bucket
FIREBASE_BUCKET=your-project.appspot.com
